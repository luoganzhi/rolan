<Window x:Class="Rolan.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Rolan.Models"
        xmlns:cvt="clr-namespace:Rolan.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="320"
        Height="600"
        Title="Rolan">
    <Window.Resources>
        <cvt:IconToImageConverter x:Key="IconConverter" />
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- 分组标签样式 -->
        <Style x:Key="GroupTabItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="2,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="重命名" Click="OnRenameGroup" />
                                    <Separator />
                                    <MenuItem Header="删除分组" Click="OnDeleteGroup" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#DDEEEEFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 快捷方式项模板 -->
        <DataTemplate x:Key="ShortcutItemTemplate" DataType="models:ShortcutItem">
            <Border Width="72" Height="Auto"
                    Padding="4" Margin="2"
                    Background="Transparent"
                    Cursor="Hand"
                    ToolTip="{Binding TargetPath}"
                    MouseDown="OnShortcutMouseDown">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="打开" Click="OnOpenShortcut" />
                        <MenuItem Header="打开文件位置" Click="OnOpenFileLocation" />
                        <Separator />
                        <MenuItem Header="上移" Click="OnMoveUp" />
                        <MenuItem Header="下移" Click="OnMoveDown" />
                        <MenuItem Header="移动到分组" ItemsSource="{Binding Source={RelativeSource AncestorType=Window}, Path=DataContext.Groups}">
                            <MenuItem.ItemTemplate>
                                <DataTemplate DataType="models:ShortcutGroup">
                                    <MenuItem Header="{Binding Name}" Click="OnMoveToGroup" />
                                </DataTemplate>
                            </MenuItem.ItemTemplate>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="编辑..." Click="OnEditShortcut" />
                        <MenuItem Header="删除" Click="OnDeleteShortcut" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <Border Width="48" Height="48"
                            CornerRadius="6"
                            Background="#FFF"
                            BorderBrush="#CCC"
                            BorderThickness="1"
                            HorizontalAlignment="Center">
                        <Image Source="{Binding IconData, Converter={StaticResource IconConverter}}"
                               Width="32" Height="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding Name}"
                               FontSize="10"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxHeight="28"
                               LineHeight="13"
                               LineStackingStrategy="BlockLineHeight"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="MainBorder"
            Background="#F0F0F0"
            CornerRadius="8"
            BorderBrush="#40000000"
            BorderThickness="1"
            Margin="4"
            MouseEnter="OnPanelMouseEnter"
            MouseLeave="OnPanelMouseLeave"
            AllowDrop="True"
            Drop="OnDrop"
            DragEnter="OnDragEnter">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.25" ShadowDepth="2" Color="Black"/>
        </Border.Effect>

        <DockPanel>
            <!-- 标题栏 -->
            <Border DockPanel.Dock="Top"
                    Background="#E8E8E8"
                    CornerRadius="8,8,0,0"
                    Height="34">
                <DockPanel>
                    <TextBlock Text="Rolan"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="#333" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0">
                        <Button Content="+"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16" Cursor="Hand"
                                Foreground="#555"
                                Click="OnBrowseAdd"
                                ToolTip="浏览添加文件" />
                        <Button Content="⚙"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14" Cursor="Hand"
                                Click="OnSettingsClick"
                                ToolTip="设置" />
                        <Button x:Name="HideBtn"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14" Cursor="Hand"
                                Click="OnHideClick"
                                ToolTip="隐藏面板">
                            <TextBlock Text="◀" FontSize="12" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 搜索框 -->
            <Border DockPanel.Dock="Top"
                    Background="#E0E0E0"
                    Padding="8,4"
                    Height="30">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="4,0"
                         Background="White"
                         BorderBrush="#C0C0C0"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         ToolTip="搜索快捷方式..." />
            </Border>

            <!-- 标签页栏 -->
            <Border DockPanel.Dock="Top"
                    Background="#E8E8E8"
                    Height="30">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="+"
                            Width="28"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#555"
                            Click="OnAddGroupClick"
                            ToolTip="添加分组" />
                    <ListBox x:Name="GroupTabBar"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource GroupTabItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:ShortcutGroup">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyHint"
                       DockPanel.Dock="Bottom"
                       Text="拖拽文件/文件夹/程序到此添加"
                       FontSize="12"
                       Foreground="#AAA"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Visibility="Collapsed" />

            <!-- 快捷方式网格 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="4"
                          Background="Transparent"
                          AllowDrop="True">
                <ItemsControl x:Name="ShortcutGrid"
                              ItemsSource="{Binding GetFilteredItems}"
                              ItemTemplate="{StaticResource ShortcutItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
