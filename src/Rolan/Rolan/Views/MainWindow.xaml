<Window x:Class="Rolan.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Rolan.Models"
        xmlns:cvt="clr-namespace:Rolan.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Width="360"
        Height="720"
        MinWidth="280"
        MinHeight="420"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        PreviewTextInput="OnWindowPreviewTextInput"
        Title="Rolan">
    <Window.Resources>
        <cvt:IconToImageConverter x:Key="IconConverter" />
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis" />
        <cvt:NullToVisibilityConverter x:Key="NullToVis" />
        <cvt:ShortcutTypeToGlyphConverter x:Key="ShortcutTypeGlyph" />
        <cvt:ShortcutTooltipConverter x:Key="ShortcutTooltip" />

        <!-- 分组标签样式 -->
        <Style x:Key="GroupTabItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="2,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="AllowDrop" Value="True" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnGroupPreviewMouseLeftButtonDown" />
            <EventSetter Event="MouseMove" Handler="OnGroupMouseMove" />
            <EventSetter Event="DragOver" Handler="OnGroupDragOver" />
            <EventSetter Event="Drop" Handler="OnGroupDrop" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <Border.ContextMenu>
                                <ContextMenu Opened="OnContextMenuOpened" Closed="OnContextMenuClosed">
                                    <MenuItem Header="重命名" Click="OnRenameGroup" />
                                    <Separator />
                                    <MenuItem Header="删除分组" Click="OnDeleteGroup" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#DDEEEEFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FrequentGroupToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="2,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#DDEEEEFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShortcutListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#22006DCC" />
                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#66006DCC" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#14006DCC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 快捷方式项模板 -->
        <DataTemplate x:Key="ShortcutItemTemplate" DataType="models:ShortcutItem">
            <Border Width="72" Height="92"
                    Padding="4" Margin="2"
                    Background="Transparent"
                    Cursor="Hand"
                    ToolTip="{Binding Converter={StaticResource ShortcutTooltip}}"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="OnShortcutPreviewMouseLeftButtonDown"
                    MouseMove="OnShortcutMouseMove"
                    MouseLeftButtonUp="OnShortcutMouseLeftButtonUp"
                    DragOver="OnShortcutDragOver"
                    Drop="OnShortcutDrop">
                <Border.ContextMenu>
                    <ContextMenu Opened="OnShortcutContextMenuOpened" Closed="OnContextMenuClosed">
                        <MenuItem Header="打开" Click="OnOpenShortcut" />
                        <MenuItem Header="打开文件位置" Click="OnOpenFileLocation" />
                        <Separator />
                        <MenuItem Header="复制目标" Click="OnCopyTargetPath" />
                        <MenuItem Header="复制命令行" Click="OnCopyCommandLine" />
                        <Separator />
                        <MenuItem Header="创建副本" Click="OnDuplicateShortcut" />
                        <Separator />
                        <MenuItem Header="上移" Click="OnMoveUp" />
                        <MenuItem Header="下移" Click="OnMoveDown" />
                        <MenuItem Header="移动到分组">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="{x:Type MenuItem}">
                                    <Setter Property="Header" Value="{Binding Name}" />
                                    <EventSetter Event="Click" Handler="OnMoveToGroup" />
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="编辑..." Click="OnEditShortcut" />
                        <MenuItem Header="重置使用记录" Click="OnResetShortcutStats" />
                        <MenuItem Header="删除" Click="OnDeleteShortcut" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <Border Width="48" Height="48"
                            CornerRadius="6"
                            Background="#FFF"
                            BorderBrush="#CCC"
                            BorderThickness="1"
                            HorizontalAlignment="Center">
                        <Grid>
                            <TextBlock Text="{Binding Type, Converter={StaticResource ShortcutTypeGlyph}}"
                                       Visibility="{Binding IconData, Converter={StaticResource NullToVis}}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#607080"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Image Source="{Binding IconData, Converter={StaticResource IconConverter}}"
                                   Width="32" Height="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding Name}"
                               FontSize="10"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxHeight="28"
                               LineHeight="13"
                               LineStackingStrategy="BlockLineHeight"
                               Margin="0,2,0,0" />
                    <Border Background="#E8EEF7"
                            CornerRadius="3"
                            Padding="3,1"
                            Margin="4,2,4,0"
                            HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsSearching, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding GroupName}"
                                   FontSize="9"
                                   Foreground="#506070"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="58" />
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="MainBorder"
            Background="#F0F0F0"
            CornerRadius="8"
            BorderBrush="#40000000"
            BorderThickness="1"
            Margin="4"
            MouseEnter="OnPanelMouseEnter"
            MouseLeave="OnPanelMouseLeave"
                    AllowDrop="True"
                    Drop="OnDrop"
                    DragEnter="OnDragEnter"
                    DragOver="OnDragOver">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.25" ShadowDepth="2" Color="Black"/>
        </Border.Effect>

        <DockPanel>
            <!-- 标题栏 -->
            <Border DockPanel.Dock="Top"
                    Background="#E8E8E8"
                    CornerRadius="8,8,0,0"
                    Height="34"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <DockPanel>
                    <TextBlock Text="Rolan"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="#333" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0">
                        <Button Content="+"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16" Cursor="Hand"
                                Foreground="#555"
                                Click="OnAddMenuClick"
                                ToolTip="添加快捷方式" />
                        <Button Content="⚙"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14" Cursor="Hand"
                                Click="OnSettingsClick"
                                ToolTip="设置" />
                        <Button x:Name="HideBtn"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14" Cursor="Hand"
                                Click="OnHideClick"
                                ToolTip="隐藏面板">
                            <TextBlock Text="◀" FontSize="12" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 搜索框 -->
            <Border DockPanel.Dock="Top"
                    Background="#E0E0E0"
                    Padding="8,4"
                    Height="30">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="4,0"
                         Background="White"
                         BorderBrush="#C0C0C0"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         KeyDown="OnSearchKeyDown"
                         ToolTip="搜索快捷方式..." />
            </Border>

            <!-- 标签页栏 -->
            <Border DockPanel.Dock="Top"
                    Background="#E8E8E8"
                    Height="30">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="+"
                            Width="28"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#555"
                            Click="OnAddGroupClick"
                            ToolTip="添加分组" />
                    <ToggleButton x:Name="FrequentGroupButton"
                                  DockPanel.Dock="Left"
                                  Content="常用"
                                  IsChecked="{Binding IsFrequentGroupSelected, Mode=TwoWay}"
                                  Style="{StaticResource FrequentGroupToggle}"
                                  ToolTip="最近和常用快捷方式" />
                    <ListBox x:Name="GroupTabBar"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource GroupTabItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:ShortcutGroup">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyHint"
                       DockPanel.Dock="Bottom"
                       Text="拖拽文件/文件夹/程序到此添加"
                       FontSize="12"
                       Foreground="#AAA"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Visibility="{Binding HasNoFilteredItems, Converter={StaticResource BoolToVis}}" />

            <ResizeGrip DockPanel.Dock="Bottom"
                        Width="16"
                        Height="16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,6,6" />

            <!-- 快捷方式网格 -->
            <ListBox x:Name="ShortcutGrid"
                     ItemsSource="{Binding FilteredItems}"
                     SelectedItem="{Binding SelectedShortcut, Mode=TwoWay}"
                     ItemTemplate="{StaticResource ShortcutItemTemplate}"
                     ItemContainerStyle="{StaticResource ShortcutListBoxItem}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="4"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="False"
                     AllowDrop="True"
                     DragOver="OnDragOver"
                     Drop="OnDrop"
                     SelectionChanged="OnShortcutGridSelectionChanged"
                     KeyDown="OnShortcutGridKeyDown">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
