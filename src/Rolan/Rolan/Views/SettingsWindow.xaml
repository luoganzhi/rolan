<Window x:Class="Rolan.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rolan 设置"
        Width="420"
        Height="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="26" />
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Margin" Value="0,10" />
        </Style>
    </Window.Resources>

    <ScrollViewer Background="#F8F8F8" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- 标题 -->
            <TextBlock Text="Rolan 设置" FontSize="20" FontWeight="Bold"
                       Margin="0,4,0,16" Foreground="#2C3E50" FontFamily="Segoe UI" />

            <!-- 基本设置 -->
            <TextBlock Text="基本行为" FontSize="13" FontWeight="SemiBold"
                       Foreground="#7F8C8D" Margin="0,0,0,4" />
            <Border Background="White" CornerRadius="6" Padding="14,6">
                <StackPanel>
                    <CheckBox IsChecked="{Binding AutoHide}" Content="贴边自动隐藏" />
                    <CheckBox IsChecked="{Binding HideWhenLostFocus}" Content="失去焦点时自动隐藏" />
                    <CheckBox IsChecked="{Binding HideAfterLaunch}" Content="启动快捷方式后隐藏面板" />
                    <CheckBox IsChecked="{Binding TopMost}" Content="始终保持窗口置顶" />
                    <CheckBox IsChecked="{Binding MousePenetration}" Content="鼠标穿透面板" />
                </StackPanel>
            </Border>

            <Separator />

            <!-- 外观 -->
            <TextBlock Text="外观" FontSize="13" FontWeight="SemiBold"
                       Foreground="#7F8C8D" Margin="0,0,0,4" />
            <Border Background="White" CornerRadius="6" Padding="14,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="主题" Width="60" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="位置" Width="60" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox ItemsSource="{Binding PanelSides}"
                                  SelectedIndex="{Binding SelectedPanelSideIndex, Mode=TwoWay}" />
                    </StackPanel>
                    <CheckBox IsChecked="{Binding AutoFitPanelHeight}" Content="按内容自动调整面板高度" />
                </StackPanel>
            </Border>

            <Separator />

            <!-- 系统 -->
            <TextBlock Text="系统" FontSize="13" FontWeight="SemiBold"
                       Foreground="#7F8C8D" Margin="0,0,0,4" />
            <Border Background="White" CornerRadius="6" Padding="14,6">
                <StackPanel>
                    <CheckBox IsChecked="{Binding AutoStart}" Content="开机自启" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                        <TextBlock Text="热键" Width="60" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox ItemsSource="{Binding HotkeyModifierOptions}"
                                  SelectedIndex="{Binding SelectedHotkeyModifierIndex, Mode=TwoWay}" />
                        <ComboBox ItemsSource="{Binding HotkeyKeyOptions}"
                                  SelectedIndex="{Binding SelectedHotkeyKeyIndex, Mode=TwoWay}"
                                  Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="默认 Alt + Space；若被占用会回退到 Ctrl + Alt + R。"
                               FontSize="11" Foreground="#95A5A6" Margin="2,2,0,8" />
                </StackPanel>
            </Border>

            <Separator />

            <!-- 数据 -->
            <TextBlock Text="数据管理" FontSize="13" FontWeight="SemiBold"
                       Foreground="#7F8C8D" Margin="0,0,0,4" />
            <Border Background="White" CornerRadius="6" Padding="14,10">
                <StackPanel>
                    <WrapPanel Margin="0,4">
                        <Button Content="导出数据" Width="90" Height="30"
                                Command="{Binding ExportDataCommand}"
                                Background="#3498DB" Foreground="White"
                                BorderThickness="0" FontSize="12" Cursor="Hand" />
                        <Button Content="导入数据" Width="90" Height="30" Margin="8,0,0,0"
                                Command="{Binding ImportDataCommand}"
                                Background="#7F8C8D" Foreground="White"
                                BorderThickness="0" FontSize="12" Cursor="Hand" />
                        <Button Content="打开目录" Width="90" Height="30" Margin="8,0,0,0"
                                Command="{Binding OpenDataDirectoryCommand}"
                                Background="#5D6D7E" Foreground="White"
                                BorderThickness="0" FontSize="12" Cursor="Hand" />
                        <Button Content="启用便携" Width="90" Height="30" Margin="8,0,0,0"
                                Command="{Binding EnablePortableModeCommand}"
                                Background="#27AE60" Foreground="White"
                                BorderThickness="0" FontSize="12" Cursor="Hand" />
                    </WrapPanel>
                    <TextBlock Text="数据目录" FontSize="12" Foreground="#7F8C8D" Margin="0,10,0,2" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="当前模式" FontSize="12" Foreground="#7F8C8D" />
                        <TextBlock Text="{Binding DataModeDescription}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#34495E"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding DataDirectory}"
                               ToolTip="{Binding DataDirectory}"
                               FontSize="11"
                               Foreground="#95A5A6"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <Button Content="保 存" Width="100" Height="34"
                    HorizontalAlignment="Right" Margin="0,16,0,0"
                    Command="{Binding SaveCommand}"
                    Background="#2ECC71" Foreground="White"
                    BorderThickness="0" FontSize="13" FontWeight="Bold"
                    Cursor="Hand" Click="OnSaveClick" />
        </StackPanel>
    </ScrollViewer>
</Window>
